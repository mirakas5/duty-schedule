# NEXTRADE IT전략본부 당직표 - 환경변수 예시
# (조회·일상 편집은 누구나 / 관리 기능만 비밀번호+IP 게이트)

# SQLite 경로
DB_PATH=./data/duty.sqlite

# 서버 바인드 (폐쇄망 내부)
HOST=0.0.0.0
PORT=8080

# ── 관리 기능 게이트 ──────────────────────────────
# 관리 탭(명단 업로드·스케줄 생성·공휴일 편집)만 보호. 조회/드래그/우클릭은 공개.
ADMIN_PASSWORD=nextrade            # ⚠️ 운영 전 반드시 변경
# ADMIN_PASSWORD_HASH=             # (선택) sha256 hex 저장 시 평문 대신 사용. 설정 시 우선
ADMIN_IPS=                         # 관리 허용 IP 목록(콤마). 비우면 IP게이트 끔(비번만). 예: 172.24.10.5,172.24.10.6
ADMIN_SECRET=change-me-admin-secret  # 쿠키 서명 키(긴 랜덤 권장)
ADMIN_TTL=28800                    # 관리 세션 유효시간(초) 기본 8시간
